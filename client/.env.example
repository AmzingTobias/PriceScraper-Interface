# The URL of the backend API server
# Set both in Vercel Environment Variables for production

# Server-only: used by auth Route Handlers to call the backend directly.
# Not exposed to the browser.
API_URL=http://localhost:5000

# Client-side: used by Next.js rewrites (next.config.js) to proxy /api/*
# and /uploads/* to your backend, and by next/image remote patterns.
NEXT_PUBLIC_API_URL=http://localhost:5000
