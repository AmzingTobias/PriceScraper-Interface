# Database
DATABASE_PATH=./data/pricescraper.db

# Security
API_SECRET=your-secret-key-here-min-32-chars-long
PASSWORD_SALT_ROUNDS=12

# Scraper
SCRAPER_PATH=/path/to/scraper
SCRAPER_CONFIG_PATH=/path/to/scraper/config

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=https://pricescraper.yourdomain.com,http://localhost:3000

# Server
PORT=5000
